// 外部业务通信协议命名空间。
namespace ironmesh.protocol.external;

// 外部业务包类型，表示客户端与网关之间的数据方向。
enum IronEdgePacketKind : ubyte {
  Request = 0, // 客户端向网关发起请求。
  Response = 1, // 网关向客户端返回响应。
  Broadcast = 2 // 网关向客户端主动推送广播。
}

// 外部入口包，只允许外部客户端与网关之间使用。
table IronEdgePacket {
  kind: IronEdgePacketKind; // 外部包类型。
  request_id: ulong; // 请求与响应关联 ID，广播包可以为 0。
  service_id: uint; // 外部业务服务 ID，例如 KV 服务或游戏服务。
  message_id: uint; // 全局唯一消息 ID，用于识别 payload 的业务类型。
  payload: [ubyte]; // 业务数据内容，由 message_id 决定解析方式。
}

// 外部入口包是外部协议的根类型。
root_type IronEdgePacket;
